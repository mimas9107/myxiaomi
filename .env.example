# vacuumd sample environment configuration
# Note: do not commit real tokens or passwords.

# Required: vacuum robot token (prefer env over config.yaml)
VACUUM_ROBOT_S5_TOKEN=

# MQTT broker connection
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_AUTH_USER=
MQTT_AUTH_PASSWORD=
MQTT_TLS=false
MQTT_KEEPALIVE=60

# Optional: server overrides
# VACUUMD_PORT=8000
# VACUUMD_LOG_FILE=/tmp/myxiaomi.log
# VACUUMD_PID_FILE=/tmp/vacuumd.pid
